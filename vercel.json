{
  "version": 2,
  "buildCommand": "cd church-frontend && npm install && npm run build",
  "outputDirectory": "church-frontend/dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "src/server.js": {
      "memory": 1024,
      "maxDuration": 60
    }
  }
}
